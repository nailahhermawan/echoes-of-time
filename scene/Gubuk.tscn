[sub_resource type="GDScript" id="GDScript_qor2r"]
resource_name = "gudang_scene.gd"
script/source = "extends Node2D

@onready var player = $Player
@onready var dialog = $Player/DialogUi
@onready var objective_ui = $CanvasLayer/ObjectiveUi
@onready var fade = $CanvasLayer/FadeRect

func _ready():
	fade.modulate.a = 1.0
	var tween = create_tween()
	tween.tween_property(fade, \"modulate:a\", 0.0, 0.5)

func _dialog_finished():
	player.unlock()
	objective_ui.set_objective(\"Ambil kain di atas meja.\")
"

