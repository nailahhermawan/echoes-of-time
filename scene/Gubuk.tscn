[sub_resource type="GDScript" id="GDScript_t6737"]
resource_name = "objui"
script/source = "extends Control

@onready var label = $PanelContainer/MarginContainer/Label

func _ready():
	visible = false  # sembunyiin dulu saat game start

func set_objective(text: String):
	label.text = text
	visible = true
"

